# EB Payments — переменные окружения

# === Локальная разработка ===
DATABASE_URL=postgresql://eb:eb_secret@localhost:5432/eb_payments
JWT_SECRET=change-this-in-production
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# === Продакшен (Render API) ===
# DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
# RUN_MIGRATIONS=true
# RUN_SEED=true
# CORS_ORIGIN=https://your-app.vercel.app
# WEB_URL=https://your-app.vercel.app

# === Redis не используется в коде — можно не задавать
# REDIS_URL=redis://localhost:6379

# === Админ-доступ (обязательно задать в продакшене!) ===
# Если не задать — при каждом seed сгенерируется случайный пароль и выведется в лог один раз.
ADMIN_EMAIL=admin@ebpayments.com
ADMIN_PASSWORD=
PLATFORM_EMAIL=platform@ebpayments.com
PLATFORM_PASSWORD=

# === Email (Brevo бесплатно: 300/день) ===
# РЕКОМЕНДУЕТСЯ: HTTP API вместо SMTP — на бесплатном тарифе Render SMTP-порты (25/465/587) заблокированы,
# а API работает через обычный HTTPS и блокировке не подвержен.
# Взять ключ: Brevo -> SMTP & API -> API Keys -> Generate a new API key
BREVO_API_KEY=

# Альтернатива (только если сервис НЕ на бесплатном тарифе Render, иначе будет Connection timeout):
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=EB Payments <noreply@yourdomain.com>
# SUPPORT_EMAIL=support@ebpayments.com

# === Stripe (test mode бесплатно) ===
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# === Google reCAPTCHA v2 (бесплатно) ===
# Получить: https://www.google.com/recaptcha/admin/create → тип "v2 Checkbox"
# Render (API):
# RECAPTCHA_SECRET_KEY=your_secret_key
# Vercel (сайт):
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key
